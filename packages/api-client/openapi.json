          "403": {
            "description": "Insufficient permission"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      },
      "post": {
        "tags": [
          "roles"
        ],
        "operationId": "create_role",
        "requestBody": {
          "content": {
            "application/json": {
