{
  "name": "@open-relay/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/generated/schema.ts"
  },
  "scripts": {
    "gen:api": "node ./scripts/fetch-openapi.mjs && openapi-typescript ./openapi.json -o ./src/generated/schema.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.0"
  }
}
