# Where the HTTP server binds.
LISTEN_ADDR=0.0.0.0:8080

# MySQL connection string (matches infra/docker-compose.yml defaults).
DATABASE_URL=mysql://root:openrelay@127.0.0.1:3306/openrelay

# HMAC secret for signing/verifying local-auth JWTs. REQUIRED: at least 32
# bytes of high-entropy random data — the server refuses to boot with a short
# or placeholder value. Generate one with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME

# AEAD key for encrypting secrets at rest (OAuth client secret, backend tokens).
# REQUIRED, MANDATORY at boot: base64 that decodes to exactly 32 bytes, and it
# must differ from JWT_SECRET. Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME

# Deployment environment: "development" or "production". Defaults to production
# when unset. Development enables the Swagger UI at /docs + /openapi.json (so
# `pnpm gen:api` works) and relaxes the SSRF guard for localhost OAuth endpoints.
ENVIRONMENT=development

# Base URL the API is reachable at from browsers — used for OAuth redirect_uri.
PUBLIC_API_URL=http://localhost:8080

# Base URL of the admin SPA — post-OAuth-callback redirect target.
ADMIN_URL=http://localhost:5173

# Absolute URL the embed SDK bundle (open-relay.js) is served from. The admin
# builds a copy-paste <script> snippet from this for each form. Optional: when
# unset it defaults to {PUBLIC_API_URL}/embed/open-relay.js. Point it at wherever
# you host the bundle (e.g. a CDN: https://cdn.example.com/open-relay.js).
EMBED_SDK_URL=http://localhost:8080/embed/open-relay.js

# Filesystem path the server reads the embed SDK bundle from to serve it at
# GET /embed/open-relay.js. Relative paths resolve from the working directory
# (the repo root under `cargo run`). Run `pnpm --filter @open-relay/embed-sdk
# build` to produce it. Defaults to the Vite build output below.
EMBED_SDK_PATH=apps/embed-sdk/dist/open-relay.js

# Set the Secure attribute on the OAuth state cookie. Must be false when
# serving the API over plain HTTP locally.
COOKIE_SECURE=false

# Logging filter (see tracing-subscriber EnvFilter syntax).
RUST_LOG=info,open_relay_server=debug,open_relay_core=debug
