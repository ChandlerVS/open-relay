# Where the HTTP server binds.
LISTEN_ADDR=0.0.0.0:8080

# MySQL connection string (matches infra/docker-compose.yml defaults).
DATABASE_URL=mysql://root:openrelay@127.0.0.1:3306/openrelay

# HMAC secret for signing/verifying local-auth JWTs. Replace before deploying.
JWT_SECRET=dev-only-change-me

# Base URL the API is reachable at from browsers — used for OAuth redirect_uri.
PUBLIC_API_URL=http://localhost:8080

# Base URL of the admin SPA — post-OAuth-callback redirect target.
ADMIN_URL=http://localhost:5173

# Set the Secure attribute on the OAuth state cookie. Must be false when
# serving the API over plain HTTP locally.
COOKIE_SECURE=false

# Logging filter (see tracing-subscriber EnvFilter syntax).
RUST_LOG=info,open_relay_server=debug,open_relay_core=debug
